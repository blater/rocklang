include "test/Assert.rkr"

sub main() {
  dim s1: string := "Hello";
  AssertEQ("strings: basic string length", 5, length(s1));

  dim s3: string := "";
  AssertEQ("strings: empty string length", 0, length(s3));

  dim arr: int[] := [];
  AssertEQ("arrays: empty array length", 0, length(arr));

  append(arr, 10);
  append(arr, 20);
  append(arr, 30);
  AssertEQ("arrays: basic array length", 3, length(arr));

  dim strs: string[] := [];
  append(strs, "one");
  append(strs, "two");
  append(strs, "three");
  AssertEQ("arrays: string array length", 3, length(strs));
}


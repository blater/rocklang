sub main() {
  // Basic byte variable and to_string
  dim b: byte := 65;
  print("byte value: ");
  print(to_string(b));
  print("\n");

  // to_int
  dim n: int := to_int(b);
  print("to_int: ");
  print(to_string(n));
  print("\n");

  // to_byte
  dim b2: byte := to_byte(200);
  print("to_byte(200): ");
  print(to_string(b2));
  print("\n");

  // Silent truncation: 300 mod 256 = 44
  dim b3: byte := to_byte(300);
  print("to_byte(300) truncated: ");
  print(to_string(b3));
  print("\n");

  // Arithmetic via int promotion
  dim sum: int := to_int(b) + to_int(b2);
  print("65 + 200 = ");
  print(to_string(sum));
  print("\n");

  // byte arrays
  dim arr: byte[] := [];
  append(arr, to_byte(10));
  append(arr, to_byte(20));
  append(arr, to_byte(30));
  print("array length: ");
  print(to_string(length(arr)));
  print("\n");
  print("arr[1] = ");
  print(to_string(to_int(get(arr, 1))));
  print("\n");

  // to_string on int (default _Generic branch)
  dim i: int := 42;
  print("to_string(int): ");
  print(to_string(i));
  print("\n");

  print("Done\n");
}

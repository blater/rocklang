// Simplified peek/poke test using direct printf instead of print()
// This avoids the strlen() crash in sccz80

sub main() {
  printf("Testing peek/poke on ZXN\n");

  // Test 1: poke 42 to address 28672 (0x7000), peek it back
  dim addr1: word := to_word(28672);
  dim val1: byte := to_byte(42);
  poke(addr1, val1);
  dim result1: byte := peek(addr1);

  if (result1 = val1) then
    printf("Test 1: PASS (42 stored/retrieved)\n");
  else
    printf("Test 1: FAIL\n");

  // Test 2: poke 100 to address 28673 (0x7001)
  dim addr2: word := to_word(28673);
  dim val2: byte := to_byte(100);
  poke(addr2, val2);
  dim result2: byte := peek(addr2);

  if (result2 = val2) then
    printf("Test 2: PASS (100 stored/retrieved)\n");
  else
    printf("Test 2: FAIL\n");

  printf("peek/poke test complete\n");
}

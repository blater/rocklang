include "test/Assert.rkr"

sub main() {
  dim s: string := "Hello World";

  AssertEquals("index to end A",   "Hello World", substring(s, 1));
  AssertEquals("index to end B",   "World",       substring(s, 7));
  AssertEquals("index to end C",   " World",      substring(s, 6));

  AssertEquals("inclusive range A", "Hello",   substring(s, 1, 5)); 
  AssertEquals("inclusive range B", "World",   substring(s, 7, 11));
  AssertEquals("inclusive range C", " ",       substring(s, 6, 6));

  AssertEquals("indexed from end (negative index) A", "World", substring(s, -5));
  AssertEquals("indexed from end (negative index) B", "ld", substring(s, -2));  
  AssertEquals("indexed from end (negative index) C", "World", substring(s, -5, -1));

}

sub main() {
  dim s: string := "0123456789";

  // Test all positive indices (1-indexed - Rock default)
  print("=== 1-indexed tests ===\n");
  print(substring(s, 1));     print("\n");  // "0123456789"
  print(substring(s, 6));     print("\n");  // "56789"
  print(substring(s, 10));    print("\n");  // "9"
  print(substring(s, 1, 3));  print("\n");  // "012"
  print(substring(s, 4, 7));  print("\n");  // "3456"
  print(substring(s, 9, 10)); print("\n");  // "89"

  print("All substring tests completed successfully!\n");
}

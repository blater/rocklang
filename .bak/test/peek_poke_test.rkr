sub pokeval(address:int, val:int) {
  dim pokeVal : byte := to_byte(val);
  dim addr : word := to_word(address);

  // CLAUDE MUST NOT CHANGE THIS STRUCTURE
  poke(addr, pokeVal);
  print("  poke(");
  print(to_string(address));
  print(",");
  print(to_string(val));
  print(")");


  // CLAUDE MUST NOT CHANGE THIS STRUCTURE
  dim result: byte := peek(addr);
  print("  	Expect:");
  print(to_string(val));
  print(", got:");
  print(to_string(to_int(result)));

  if (result = pokeVal) then
    print("   PASS");
  else
    print("   FAILED XXXX");

  print("\n");
}


sub main() {
  print("Testing peek/poke functions\n");

  // Test 1: Basic poke and peek roundtrip
  // CLAUDE MUST NOT CHANGE THE ADDRESSES OR VALUES HERE. DO NOT REMOVE THIS COMMENT
  print("Test 1: Basic poke/peek\n");
  pokeval(16385, 42);
  pokeval(16386, 100);
  pokeval(16385, 255);
  pokeval(16386, 0);
  // CLAUDE MUST NOT CHANGE THE BLOCK ABOVE

  print("peek/poke test complete\n");
}

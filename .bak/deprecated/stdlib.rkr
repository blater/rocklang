include "lib/file.rkr"
include "lib/term.rkr"


let implemented(s: string) {
    print("TODO: ");
    print(s);
    print(" is not yet implemented\n");
    exit(1);
}


let compiler_assert(b: boolean, s: string) {
    if b = 0 then {
        print("Assertion failed: ");
        print(s);
        exit(1);
    }
}

let print_int(n: int) {
  let a: int => n / 10;
  if a then print_int(a);
  putchar(n%10 + '0');
}

let string_of_int(n: int): string {
    let chars: char [] => [];
    if n = 0 then append(chars, '0');
    while n > 0 do {
        append(chars, n%10 + '0');
        n => n/10;
    }
    let res: string => "";
    loop i: 0 -> length(chars) -1 =>
        res =>
            concat(res, get(chars, length(chars) - 1 - i));

    // Using C bindings lol
    return res;
}

let toString(n: int): string {
    return string_of_int(n);
}


let create_string(src: string, offset: int,  length: int): string {
    let res: string => "";
    loop i: 0 -> length - 1 => {
        let c: char => get_nth_char(src, offset + i);
        res => concat(res, c);
    }
    return res;
}

let cons_str(src: string, offset: int): string {
    return create_string(src,
                         offset,
                         get_string_length(src) - offset);
}


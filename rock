#!/bin/bash
set -e
ROCK_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEBUG=0

sourcefile=""
target="cc"

while [ $# -gt 0 ]; do
  case "$1" in
    --target=*)
      target=$( echo $1 | cut -f2 -d"=" )
      shift 1
      ;;
    --debug)
      DEBUG=1; shift;;
    #-?*)
    #  echo "Unknown option: $1" >&2; usage ;;
    *) if [ "$sourcefile" = "" ]; then
         sourcefile="$1"
         source_abs=$(cd "$(dirname "$sourcefile")" && pwd)/$(basename "$sourcefile")
         exe=$( basename $sourcefile | cut -f1 -d"." )".exe"
       else
         exe="$1"
       fi
       shift
       ;;
  esac
done

exe_dir=$(cd "$(dirname "$exe" 2>/dev/null || dirname .)" && pwd)
exe_abs="$exe_dir/$(basename "$exe")"

echo "compile $sourcefile to $exe with $target"
make -C "$ROCK_ROOT" "target-${target}" SRC="$source_abs" OUT="$exe_abs"



if [ $DEBUG -eq 0 ];then
  rm -f ${exe_abs}.c
fi


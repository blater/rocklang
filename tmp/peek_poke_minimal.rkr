// Minimal peek/poke test - no strings, no print, just memory operations
sub main(): void => {
  // Test 1: poke and peek roundtrip
  poke(to_word(1000), to_byte(42));
  dim result: byte := peek(to_word(1000));

  // Test 2: another value
  poke(to_word(2000), to_byte(255));
  dim result2: byte := peek(to_word(2000));

  // Test 3: overwrite
  poke(to_word(1000), to_byte(0));
  dim result3: byte := peek(to_word(1000));
}

record array_wrapper => {
  Items: int [],
  Names: string [],
}

sub func(): array_wrapper => {
  dim a: array_wrapper => {
    Items => NULL,
    Names => NULL,
  };
  dim items: int [] => [];
  a.Items := items;
  dim names: string [] := [];
  a.Names := names;
  append(a.Items, 1);
  append(names, "First\n");
  return a;
}

sub main() {
  dim a: array_wrapper := func();
  dim names: string [] := a.Names;
  print("\n");
  for name: names {
    print(name);
  }
  print("Done\n");
}

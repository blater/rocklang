include "Assert.rkr"

sub main() {
  Assert a;
  word w := 1000;
  a.AssertEQ("basic word", 1000, w);

  int n := to_int(w);
  a.AssertEQ("to int", 1000, n);

  word w2 := to_word(60000);
  a.AssertEQ("to word", 60000, w2);

  // Silent truncation: 70000 mod 65536 = 4464
  word w3 := to_word(70000);
  a.AssertEQ("max value wrap around", 4464, w3);

  int sum := to_int(w) + to_int(w2);
  a.AssertEQ("arithmetic via int promotion", 61000, sum);

  word[] arr := [];
  append(arr, to_word(100));
  append(arr, to_word(200));
  append(arr, to_word(300));
  a.AssertEQ("word arrays len", 3, length(arr));
  a.AssertEQ("word arrays val", 200, get(arr,1));
}

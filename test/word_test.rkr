include "test/Assert.rkr"

sub main() {
  dim w: word := 1000;
  AssertEQ("basic word", 1000, w);

  dim n: int := to_int(w);
  AssertEQ("to int", 1000, n);

  dim w2: word := to_word(60000);
  AssertEQ("to word", 60000, w2);

  // Silent truncation: 70000 mod 65536 = 4464
  dim w3: word := to_word(70000);
  AssertEQ("max value wrap around", 4464, w3);

  dim sum: int := to_int(w) + to_int(w2);
  AssertEQ("arithmetic via int promotion", 61000, sum);

  dim arr: word[] := [];
  append(arr, to_word(100));
  append(arr, to_word(200));
  append(arr, to_word(300));
  AssertEQ("word arrays len", 3, length(arr));
  AssertEQ("word arrays val", 200, get(arr,1));
}

include "Assert.rkr"
Assert a;

sub main() {
  // Basic word variable and to_string
  word w := to_word(1000);
  a.AssertEQ("word is 1000", 1000, to_int(w));

  // to_int
  int n := to_int(w);
  a.AssertEQ("int n is 1000", 1000, n);

  // Silent truncation: 70000 mod 65536 = 4464
  word w1 := to_word(70000);
  a.AssertEQ("word bigger than 65535 is truncated", to_int(w1), 4464);

  // Arithmetic via int promotion (1000 + 4464)
  int sum := to_int(w) + to_int(w1);
  a.AssertEQ("addition via int promotion", sum, 5464);

  // word arrays
  word[] arr := [];
  append(arr, to_word(100));
  append(arr, to_word(200));
  append(arr, to_word(300));

  a.AssertEQ("word arrays assigned ok", length(arr), 3);
  a.AssertEQ("word arrays element[1]", 200, to_int(get(arr,1)));

  // to_string on int (default branch still works)
  int i := 42;
  a.AssertEquals("to_string on an int", toString(i), "42");

  // to_string on byte still works (regression)
  byte b := to_byte(99);
  a.AssertEquals("to_string on a byte", toString(b), "99");

  print("Done\n");
}

// Aggregate field aliasing — Shape 4.
//
// Overwriting an aggregate field emits __handle_release on the old value,
// but record-literal field-init never retained for that slot. The release
// "steals" a refcount share from the original source. See
// wikiroot/pages/concepts/aggregate-field-aliasing-leak.md.
//
// EXPECTED TO FAIL today: at scope exit, releasing ii hits an
// already-freed block (or the second AssertEQ reads freed memory).
// Will pass once record-literal field-init retains aggregate borrower
// sources (matching the field-overwrite release).

include "../Assert.rkr"

Assert as;

record Inner { int x }
record Outer { Inner i, int n }

sub mkInner(int v) returns Inner {
  Inner r := {x := v};
  return r;
}

sub main() {
  Inner ii := mkInner(7);
  Outer o := {i := ii, n := 0};
  o.i := mkInner(99);  // releases o.i (== ii block) without prior retain
  as.AssertEQ("ii must still be readable after o.i overwrite", 7, ii.x);
  as.AssertEQ("o.i.x is the new value", 99, o.i.x);
}

// Aggregate field aliasing — Shape 1.
//
// Reassigning the original handle releases the block that the holder's
// field still aliases, leaving the field dangling. See
// wikiroot/pages/concepts/aggregate-field-aliasing-leak.md.
//
// EXPECTED TO FAIL today: print(o.i.x) reads through a freed Inner block.
// Will pass once record-literal field-init retains aggregate borrower
// sources AND records carry field-walking destructors.

include "../Assert.rkr"

Assert as;

record Inner { int x }
record Outer { Inner i, int n }

sub mkInner(int v) returns Inner {
  Inner r := {x := v};
  return r;
}

sub main() {
  Inner ii := mkInner(7);
  Outer o := {i := ii, n := 0};
  ii := mkInner(99);  // releases the original ii block; o.i is now dangling
  as.AssertEQ("o.i.x must still be 7 after ii reassignment", 7, o.i.x);
}

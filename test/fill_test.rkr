include "Assert.rkr"

// Smoke test for fill(x0, y0, x1, y1). Under run_tests.sh stdout
// is piped so host_caps.plot is 0 — we only assert calls return
// normally.

sub main() {
  Assert a;

  // Single-pixel rect (degenerate).
  fill(50, 50, 50, 50);

  // Small box.
  fill(10, 10, 20, 20);

  // Row (1-pixel tall).
  fill(0, 30, 255, 30);

  // Column (1-pixel wide).
  fill(100, 0, 100, 191);

  // Reversed endpoints — should normalise.
  fill(200, 150, 150, 100);

  // Rect that overhangs the bottom of the screen — per-row clip.
  fill(0, 180, 50, 200);

  // XOR mode — fill twice to erase.
  over(1);
  fill(64, 64, 128, 128);
  fill(64, 64, 128, 128);
  over(0);

  // Panel + outline combo.
  fill(180, 20, 240, 60);
  draw(180, 20, 240, 20);
  draw(240, 20, 240, 60);
  draw(240, 60, 180, 60);
  draw(180, 60, 180, 20);

  a.AssertEQ("fill smoke", 1, 1);
}

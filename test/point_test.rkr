include "Assert.rkr"

// Host test for point(byte x, byte y) — reads pixel state from the
// shadow framebuffer maintained by plot.c. Under run_tests.sh stdout
// is piped so host_caps.plot is 0; plot() still updates the shadow
// so point() reads are meaningful regardless of the capability flag.

sub main() {
  Assert a;

  // Blank pixels read as 0.
  a.AssertEQ("unset at (0,0)",   0, to_int(point(to_byte(0),   to_byte(0))));
  a.AssertEQ("unset at (10,10)", 0, to_int(point(to_byte(10),  to_byte(10))));

  // Plot then read back.
  plot(to_byte(5), to_byte(5));
  a.AssertEQ("set at (5,5)", 1, to_int(point(to_byte(5), to_byte(5))));

  // Neighbours still unset.
  a.AssertEQ("unset at (6,5)", 0, to_int(point(to_byte(6), to_byte(5))));
  a.AssertEQ("unset at (5,6)", 0, to_int(point(to_byte(5), to_byte(6))));

  // Corner of the display.
  plot(to_byte(255), to_byte(191));
  a.AssertEQ("set at (255,191)", 1, to_int(point(to_byte(255), to_byte(191))));

  // Out-of-range y clips to 0 on both plot and point.
  a.AssertEQ("oob y=200", 0, to_int(point(to_byte(10), to_byte(200))));
}

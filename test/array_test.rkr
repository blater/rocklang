include "Assert.rkr"
Assert as;

sub dynamicIntTest(){
  int [] arr;
  for i := 0 to 10 {
    append(arr, i);
  }
  for i := 0 to length(arr) -1 {
    int n := get(arr, i);
    as.AssertEQ("dynamic int test", i, n);
  }
}

record array_wrapper {
  int[] Items,      // new syntax
  Names : string[], // old deprecated syntax
}

sub wrapFn(): array_wrapper {
  array_wrapper a := {
    Items := NULL,
    Names := NULL,
  };
  int [] items;
  a.Items := items;

  string [] names;
  a.Names := names;
  append(a.Items, 1);
  append(names, "First");
  append(a.Items, 2);
  append(names, "Second");
  append(a.Items, 3);
  append(names, "Third");

  return a;
}

sub main() {
  dynamicIntTest();

  int[2] pople;
  pople[0] := 99;
  as.AssertEQ("int fixed size array assignment", 99, get(pople,0));

  string[3] fixed;
  fixed[0] := "hello";
  fixed[1] := "world";
  as.AssertEquals("string fixed size array assignment", "world", get(fixed,1));

  string[] strings;
  append(strings, "A");
  append(strings, "B B");
  append(strings, "C C C");
  as.AssertEquals("string dynamic assign A", "A", get(strings,0));
  as.AssertEquals("string dynamic assign B", "B B", get(strings,1));
  as.AssertEquals("string dynamic assign C", "C C C", get(strings,2));

  array_wrapper a := wrapFn();
  // For the moment, you must bind them by name to use them
  string [] names := a.Names;
  as.AssertEquals("wrapped assign 1", "First", get(names,0));
  as.AssertEquals("wrapped assign 2", "Second", get(names,1));
  as.AssertEquals("wrapped assign 3", "Third", get(names,2));

  array_wrapper new_arr := {
    Items := [],
    Names := []
  };
  as.AssertEQ("empty array size", 0, length(new_arr.Items));
}


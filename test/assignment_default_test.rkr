include "Assert.rkr"
Assert a;

sub main() {
  int n;
  a.AssertEQ("int defaults to 0", 0, n);

  byte b;
  a.AssertEQ("byte defaults to 0", 0, b);

  word w;
  a.AssertEQ("word defaults to 0", 0, w);

  dword dw;
  a.AssertEQ("dword defaults to 0", 0, dw);

  string s;
  a.AssertEquals("string defaults to empty", "", s);

  int[] arr;
  a.AssertEQ("int[] defaults to length 0", 0, length(arr));

  string[] sarr;
  a.AssertEQ("string[] defaults to length 0", 0, length(sarr));
}

include "Assert.rkr"

sub pokeval(int address, int val) {
  Assert a;
  byte pokeVal := to_byte(val);
  word addr := to_word(address);

  // CLAUDE MUST NOT CHANGE THIS STRUCTURE
  poke(addr, pokeVal);

  // CLAUDE MUST NOT CHANGE THIS STRUCTURE
  byte result := peek(addr);
  string desc := concat("pokeval(", toString(address));
  desc := concat(desc, ",");
  desc := concat(desc, toString(val));
  desc := concat(desc, ")");
  a.AssertEQ(desc, val, to_int(result));
}


sub main() {
  // Test 1: Basic poke and peek roundtrip
  // CLAUDE MUST NOT CHANGE THE ADDRESSES OR VALUES HERE. DO NOT REMOVE THIS COMMENT
  pokeval(16385, 42);
  pokeval(16386, 100);
  pokeval(16385, 255);
  pokeval(16386, 0);
  // CLAUDE MUST NOT CHANGE THE BLOCK ABOVE
}

include "Assert.rkr"
Assert a;

record Person {
  string name,
  int age
}

sub makePerson(string n, int ag) returns Person {
  Person p := {name := n, age := ag};
  return p;
}

sub main() {
  // Test 1: Record construction with string literal
  Person p := {name := "Alice", age := 30};
  a.AssertEquals("record string field", "Alice", p.name);
  a.AssertEQ("record int field", 30, p.age);

  // Test 2: Record field reassignment
  p.name := "Bob";
  a.AssertEquals("record field reassign", "Bob", p.name);

  // Test 3: String field from variable (aliasing test)
  {
    string s := "Charlie";
    Person q := {name := s, age := 25};
    a.AssertEquals("record from var", "Charlie", q.name);
  }

  // Test 4: Record returned from function
  Person r := makePerson("Dave", 40);
  a.AssertEquals("record from fn", "Dave", r.name);
  a.AssertEQ("record from fn age", 40, r.age);

  // Test 5: Record in loop via function
  Person last := makePerson("init", 0);
  for i := 1 to 50 {
    last := makePerson(concat("person", toString(i)), i);
  }
  a.AssertEquals("record in loop", "person50", last.name);
  a.AssertEQ("record in loop age", 50, last.age);
}

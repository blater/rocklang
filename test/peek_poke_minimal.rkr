include "Assert.rkr"

sub main() {
  Assert a;
  // Test 1: poke value 42 to address 0xE000 (57344), peek it back
  word addr1 := to_word(57344);
  byte val1 := to_byte(42);
  poke(addr1, val1);
  byte result1 := peek(addr1);
  a.AssertEQ("Test 1: peek/poke 42", to_int(val1), to_int(result1));

  // Test 2: poke value 100 to address 0xE001 (57345), peek it back
  word addr2 := to_word(57345);
  byte val2 := to_byte(100);
  poke(addr2, val2);
  byte result2 := peek(addr2);
  a.AssertEQ("Test 2: peek/poke 100", to_int(val2), to_int(result2));
}

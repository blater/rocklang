include "Assert.rkr"
Assert a;

sub fun_with_args(int a1, string[] names) returns string {
  string result :="arg count:";
  result := concat(result, (toString(length(names))));
  result := concat(result, " value:");
  result := concat(result,toString(a1));
  return result;
}

sub main() {
  string[] args := [];
  append(args, "test1");
  append(args, "test2");

  string result := fun_with_args(42, args);

  a.AssertEquals("Testing function with args", "arg count:2 value:42", result);
}

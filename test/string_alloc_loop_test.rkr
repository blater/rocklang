// ADR-0003 Phase H step 2: validates refcount-driven reclamation under load.
//
// This test runs a tight loop performing many string allocations via
// toString and concat. With Phase H's allocator switch, each allocation
// uses rock_longlived_alloc; scope cleanup releases the refcount; the
// block returns to the size-class freelist; the next iteration reuses it.
//
// Under the legacy allocate_compiler_persistent path, every iteration
// permanently leaked into the malloc-backed compiler stack, with the
// "leak" only reclaimed at program exit.
//
// With the host pool defaults (4 MB longlived), 5000 iterations without
// reclamation would consume far more than 4 MB if blocks were not being
// reused. This test running to completion proves blocks are reclaimed.

include "Assert.rkr"

Assert as;

sub main() {
  for i := 1 to 5000 {
    string s := toString(i);
    string greeting := concat("hello-", s);
    // both s and greeting go out of scope at iteration end;
    // their backing must be released to the freelist or we OOM.
  }
  as.AssertEQ("string_alloc_loop survived 5000 iterations", 1, 1);
}

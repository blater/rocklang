// ADR-0003 §10.3 / §7.6: every non-scalar return goes through
// __return_string. Three lifetime classes flow through:
//   - return of a literal       → static sentinel passes through
//   - return of a longlived val → refcount inc'd; caller transfers
//   - return of a parameter     → exercises the borrow + return pattern
//
// All three must work end-to-end and the caller must be able to use the
// returned string for the lifetime of its slot (not just transiently).

include "Assert.rkr"

Assert as;

sub returnLiteral() returns string {
  return "hello literal";
}

sub returnConcat() returns string {
  string a := "hello ";
  string b := "concat";
  return concat(a, b);
}

sub returnLocal() returns string {
  string s := concat("local ", "value");
  return s;
}

sub returnParam(string s) returns string {
  return s;
}

sub returnSubstring() returns string {
  string source := "the full string";
  return substring(source, 5, 8);
}

sub main() {
  string r1 := returnLiteral();
  as.AssertEquals("return literal", "hello literal", r1);

  string r2 := returnConcat();
  as.AssertEquals("return concat result", "hello concat", r2);

  string r3 := returnLocal();
  as.AssertEquals("return local concat", "local value", r3);

  string given := concat("passed ", "in");
  string r4 := returnParam(given);
  as.AssertEquals("return parameter", "passed in", r4);

  string r5 := returnSubstring();
  as.AssertEquals("return substring view", "full", r5);

  // Loop test: a function returning fresh strings should not leak.
  for i := 1 to 1000 {
    string r := returnConcat();
    string r_again := returnLocal();
  }
  as.AssertEQ("return loop survived 1000 iterations", 1, 1);
}

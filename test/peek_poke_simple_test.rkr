include "Assert.rkr"

sub main() {
  Assert a;
  // Test 1: poke 42 to address 28672 (0x7000), peek it back
  word addr1 := to_word(28672);
  byte val1 := to_byte(42);
  poke(addr1, val1);
  byte result1 := peek(addr1);
  a.AssertEQ("Test 1: peek/poke 42", to_int(val1), to_int(result1));

  // Test 2: poke 100 to address 28673 (0x7001)
  word addr2 := to_word(28673);
  byte val2 := to_byte(100);
  poke(addr2, val2);
  byte result2 := peek(addr2);
  a.AssertEQ("Test 2: peek/poke 100", to_int(val2), to_int(result2));
}

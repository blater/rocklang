include "Assert.rkr"

sub main() {
  Assert a;
  string s1 := "Hello";
  string s2 := " World";
  string result1 := concat(s1, s2);
  a.AssertEquals("String concatination", "Hello World", result1);

  string s3 := "ABC";
  char c := 'D';
  string result2 := concat(s3, c);
  a.AssertEquals("Test string + char (via intermediate result)", "ABCD", result2);
}

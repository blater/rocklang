// ADR-0003 §7.5: substring is a view that points into the source's bytes
// without writing a null terminator. The length-aware print path makes
// substring printable without scribbling past its logical end.
//
// Under the legacy allocate-and-copy substring + printf("%s", .data)
// emission, this test would have happened to work because every substring
// got its own null terminator. Under view semantics, printing must use
// the length-aware path or the printed text would over-run.

include "Assert.rkr"

Assert as;

sub main() {
  string greeting := "hello, world!";

  // Substring "hello" — first 5 chars.
  string head := substring(greeting, 1, 5);
  as.AssertEquals("substring head equals 'hello'", "hello", head);

  // Substring "world" — chars 8..12.
  string body := substring(greeting, 8, 12);
  as.AssertEquals("substring body equals 'world'", "world", body);

  // Substring of substring still works (view of view).
  string body_head := substring(body, 1, 3);
  as.AssertEquals("substring of substring 'wor'", "wor", body_head);

  // Print path via Rock's printf: must not over-read the substring view.
  printf(head);
  printf(" ");
  printf(body);
  printf("\n");
}

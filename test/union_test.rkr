include "Assert.rkr"

union Optional { int value, empty }

sub main() {
  Assert a;

  Optional opt := value(42);
  a.AssertEQ("value constructor sets key", opt.key, value);
  int result;
  result := 0;
  case opt {
    value : result := 1;
    empty : result := 2;
  }
  a.AssertEQ("case value key", result, 1);

  // Case with default
  result := 0;
  case opt {
    empty : result := 1;
    default: result := 99;
  }
  a.AssertEQ("case default on union", result, 99);


  Optional optEmpty := empty();
  a.AssertEQ("optEmpty constructor sets key", optEmpty.key, empty);
  result := 0;
  case optEmpty {
    value : result := 1;
    empty : result := 2;
  }
  a.AssertEQ("case empty key", result, 2);

}

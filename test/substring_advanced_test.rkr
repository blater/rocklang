include "Assert.rkr"

sub main() {
  Assert a;
  string s := "0123456789";

  // Test all positive indices (1-indexed - Rock default)
  a.AssertEquals("substring(s, 1)", "0123456789", substring(s, 1));
  a.AssertEquals("substring(s, 6)", "56789", substring(s, 6));
  a.AssertEquals("substring(s, 10)", "9", substring(s, 10));
  a.AssertEquals("substring(s, 1, 3)", "012", substring(s, 1, 3));
  a.AssertEquals("substring(s, 4, 7)", "3456", substring(s, 4, 7));
  a.AssertEquals("substring(s, 9, 10)", "89", substring(s, 9, 10));
}

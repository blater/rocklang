include "test/Assert.rkr"

sub main() {
  dim s: string := "0123456789";

  // Test all positive indices (1-indexed - Rock default)
  AssertEquals("substring(s, 1)", "0123456789", substring(s, 1));
  AssertEquals("substring(s, 6)", "56789", substring(s, 6));
  AssertEquals("substring(s, 10)", "9", substring(s, 10));
  AssertEquals("substring(s, 1, 3)", "012", substring(s, 1, 3));
  AssertEquals("substring(s, 4, 7)", "3456", substring(s, 4, 7));
  AssertEquals("substring(s, 9, 10)", "89", substring(s, 9, 10));
}

include "Assert.rkr"

sub main() {
  Assert a;
  // Test toString with literals
  a.AssertEquals("toString with literal", "42", toString(42));

  // Test toString with variables
  int num := 12345;
  a.AssertEquals("toString with variable", "12345", toString(num));

  // Test toString with expressions
  a.AssertEquals("toString with expression", "30", toString(10 + 20));

  // Test toString with negative numbers (indirectly)
  int x := 7;
  a.AssertEquals("toString with multiplication", "21", toString(x * 3));
}

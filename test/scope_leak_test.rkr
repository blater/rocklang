include "Assert.rkr"
Assert a;

sub main() {
  // =========================================================================
  // Group 1: if/else without braces (single-statement body via 'then')
  // T1.1 — string temps in wrapped body get scope cleanup
  // =========================================================================

  // 1a: concat in single-statement if body
  int flag := 1;
  string r1 := "init";
  if flag = 1 then
    r1 := concat("if-", "hit");
  a.AssertEquals("if no-brace concat", "if-hit", r1);

  // 1b: toString in single-statement else body
  string r2 := "init";
  flag := 0;
  if flag = 1 then
    r2 := "true-path";
  else
    r2 := concat("else-", toString(42));
  a.AssertEquals("else no-brace toString", "else-42", r2);

  // 1c: if/else without braces inside a loop (leak stress — 200 iters)
  int i := 0;
  string r3 := "";
  while i < 200 {
    if i = 100 then
      r3 := concat("found-", toString(i));
    else
      r3 := concat("skip-", toString(i));
    i := i + 1;
  }
  a.AssertEquals("if/else no-brace x200", "skip-199", r3);

  // 1d: nested if-then inside if-then (both braceless)
  flag := 1;
  int flag2 := 1;
  string r4 := "none";
  if flag = 1 then
    if flag2 = 1 then
      r4 := concat("both-", "true");
  a.AssertEquals("nested if-then", "both-true", r4);

  // 1e: if-then with substring (another temp-producing expression)
  string src := "Hello World";
  string r5 := "";
  if flag = 1 then
    r5 := substring(src, 1, 5);
  a.AssertEquals("if-then substring", "Hello", r5);

  // =========================================================================
  // Group 2: while/for with braces — compound body already scoped
  // These verify existing generate_compound scope management + our
  // iter_loop scope fix (T1.4) for loop-level cleanup
  // =========================================================================

  // 2a: for-range with string concat per iteration (500 iters)
  string r6 := "";
  for j := 1 to 500 {
    r6 := concat("f-", toString(j));
  }
  a.AssertEquals("for 500 concat", "f-500", r6);

  // 2b: while with toString per iteration (500 iters)
  i := 0;
  string r7 := "";
  while i < 500 {
    r7 := toString(i);
    i := i + 1;
  }
  a.AssertEquals("while 500 toString", "499", r7);

  // =========================================================================
  // Group 3: for-each with string operations in body (T1.4)
  // =========================================================================

  // 3a: foreach with concat accumulation
  string[] names := [];
  append(names, "Alice");
  append(names, "Bob");
  append(names, "Carol");
  string r8 := "";
  for n in names {
    r8 := concat(r8, n);
  }
  a.AssertEquals("foreach concat", "AliceBobCarol", r8);

  // 3b: foreach with toString on int array
  int[] nums := [];
  append(nums, 10);
  append(nums, 20);
  append(nums, 30);
  string r9 := "";
  for v in nums {
    r9 := concat(r9, toString(v));
  }
  a.AssertEquals("foreach toString", "102030", r9);

  // 3c: foreach over 100-element string array (stress)
  string[] big := [];
  for q := 0 to 99 {
    append(big, toString(q));
  }
  string r10 := "";
  for item in big {
    r10 := item;
  }
  a.AssertEquals("foreach 100 strings", "99", r10);

  // =========================================================================
  // Group 4: Combined stress — mix of all patterns
  // =========================================================================

  // 4a: if-then inside for-range, 500 iterations
  string r11 := "";
  for m := 1 to 500 {
    if m < 250 then
      r11 := toString(m);
    else
      r11 := concat("big-", toString(m));
  }
  a.AssertEquals("if-then in for 500", "big-500", r11);

  // 4b: if-then inside while, concat + toString each iteration
  i := 0;
  string r12 := "";
  while i < 300 {
    if i = 150 then
      r12 := concat("match-", toString(i));
    i := i + 1;
  }
  a.AssertEquals("if-then in while", "match-150", r12);
}

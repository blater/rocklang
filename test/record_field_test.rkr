include "Assert.rkr"
Assert as;

record array_wrapper {
  int[] Items,
  string[] Names,
}

sub wrapFn(): array_wrapper {
  array_wrapper a := {
    Items := [],
    Names := []
  };

  append(a.Items, 1);
  append(a.Items, 2);
  append(a.Items, 3);

  append(a.Names, "First");
  append(a.Names, "Second");
  append(a.Names, "Third");

  return a;
}

sub main(): void {
  array_wrapper a := wrapFn();

  int[] items := a.Items;
  as.AssertEQ("wrapped item 1", 1, get(items, 0));
  as.AssertEQ("wrapped item 2", 2, get(items, 1));
  as.AssertEQ("wrapped item 3", 3, get(items, 2));

  string[] names := a.Names;
  as.AssertEquals("wrapped name 1", "First", get(names, 0));
  as.AssertEquals("wrapped name 2", "Second", get(names, 1));
  as.AssertEquals("wrapped name 3", "Third", get(names, 2));

  array_wrapper empty := {
    Items := [],
    Names := []
  };
  as.AssertEQ("empty item length", 0, length(empty.Items));
  as.AssertEQ("empty name length", 0, length(empty.Names));
}

include "Assert.rkr"

// Smoke test for circle(cx, cy, r). Under run_tests.sh stdout is piped
// so host_caps.plot is 0 and we only assert calls return normally.

sub main() {
  Assert a;

  // r == 0 → single pixel (degenerate).
  circle(50, 50, 0);

  // r == 1 → 4 unique pixels (8-way symmetry collapses on axis).
  circle(60, 60, 1);

  // Typical small circles.
  circle(100, 96, 10);
  circle(128, 96, 30);

  // Large circle that straddles the y=191 clip boundary.
  circle(128, 170, 40);

  // Circle whose top edge is near y=0.
  circle(128, 20, 15);

  // XOR mode — draw twice to net-zero erase.
  over(1);
  circle(200, 100, 12);
  circle(200, 100, 12);
  over(0);

  // Combine with draw() — diameter line.
  circle(64, 96, 20);
  draw(44, 96, 84, 96);

  a.AssertEQ("circle smoke", 1, 1);
}

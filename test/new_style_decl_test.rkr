include "Assert.rkr"

record Point {
  int x,
  int y
}

sub main() returns void {
  Assert a;

  int n := 42;
  a.AssertEQ("int declaration", 42, n);

  string s := "hello";
  a.AssertEquals("string declaration", "hello", s);

  int m;
  a.AssertEQ("int default", 0, m);

  string t;
  a.AssertEquals("string default", "", t);

  string[] words;
  append(words, "rock");
  append(words, "on");
  a.AssertEQ("string[] length", 2, length(words));

  int[3] nums := [];
  set(nums, 0, 10);
  set(nums, 1, 20);
  set(nums, 2, 30);
  a.AssertEQ("int[3] element", 20, get(nums, 1));

  Point p := {x := 5, y := 10};
  a.AssertEQ("record field x", 5, p.x);
  a.AssertEQ("record field y", 10, p.y);
}

include "Assert.rkr"

// Host smoke test for draw(x0,y0,x1,y1). Exercises every dispatcher
// branch and the Bresenham shallow/steep split. Under run_tests.sh
// stdout is piped so host_caps.plot is 0 and the plain-text fallback
// runs — we only assert that every call returns normally.

sub main() {
  Assert a;

  // Single-pixel degenerate (both endpoints equal).
  draw(100, 100, 100, 100);

  // Horizontal — same byte, partial.
  draw(2,   10,  5,   10);
  // Horizontal — leading + full + trailing across the full row.
  draw(0,   20,  255, 20);
  // Horizontal — reversed endpoints (dispatcher sorts).
  draw(200, 30,  10,  30);

  // Vertical — top to bottom.
  draw(50,  0,   50,  191);
  // Vertical — reversed endpoints.
  draw(60,  150, 60,  5);

  // 45° diagonal.
  draw(0,   0,   63,  63);

  // Shallow general (dx > dy).
  draw(10,  100, 200, 140);
  // Steep general (dy > dx).
  draw(100, 10,  140, 180);

  // Reversed-direction shallow (x1 < x0).
  draw(200, 80,  10,  120);
  // Reversed-direction steep (y1 < y0).
  draw(80,  180, 120, 10);

  // y out of range on one endpoint — general path clips per-pixel.
  draw(0,   180, 255, 200);

  // Box outline using four draw calls.
  draw(0,   0,   31,  0);
  draw(31,  0,   31,  23);
  draw(31,  23,  0,   23);
  draw(0,   23,  0,   0);

  a.AssertEQ("draw smoke", 1, 1);
}

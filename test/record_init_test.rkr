include "Assert.rkr"

record Point {
  x: int,
  y: int,
}

record Person {
  name: string,
  age: int,
}

sub main(): void {
  Assert a;
  Point p1 := {x := 10, y := 20};
  a.AssertEQ("record init x", 10, p1.x);
  a.AssertEQ("record init y", 20, p1.y);

  Person alice := {name := "Alice", age := 30};
  a.AssertEquals("string field name", "Alice", alice.name);
  a.AssertEQ("int field age", 30, alice.age);
}

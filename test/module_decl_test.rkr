module Test;

int TRUE := 1;
int FALSE := 0;

sub printPass(string desc) {
    printf("PASS: ");
    printf(desc);
    printf("\n");
}

sub printFail(string desc, string expected, string actual) {
    printf("FAIL: ");
    printf(desc);
    printf(" (expected:");
    printf(expected);
    printf(" actual:");
    printf(actual);
    printf(")\n");
}

sub printResult(int res, string desc, string expected, string actual) returns int {
  if (res = 1) {
    printPass(desc);
  } else {
    printFail(desc, expected, actual);
  }
  return res;
}

sub printIntResult(int res, string desc, int expected, int actual) returns int {
  return printResult(res, desc, toString(expected), toString(actual));
}

sub Test.assertFalse(string desc, int value) returns int {
  if (value = 1) {
    printFail(desc, "False(0)", toString(value));
    return 0;
  } else {
    printPass(desc);
    return 1;
  }
}

sub Test.assertTrue(string desc, int value) returns int {
  if (value = 0) {
    printFail(desc, "TRUE(1)", toString(value));
    return 0;
  } else {
    printPass(desc);
    return 1;
  }
}

sub Test.assertEQ(string desc, int expected, int actual) returns int {
  return printIntResult((expected = actual), desc, expected, actual);
}

sub Test.assertNEQ(string desc, int expected, int actual) returns int {
  return printIntResult((expected != actual), desc, expected, actual);
}

sub Test.assertEquals(string desc, string expected, string actual) returns int {
  return printResult(equals(expected, actual)!=0, desc, expected, actual);
}

sub Test.assertNotEquals(string desc, string expected, string actual) returns int {
  return printResult(equals(expected, actual)=0, desc, expected, actual);
}

sub testRkrUnit() {
  Test a;
  a.assertEQ("values are equal", 2, 2);
  a.assertNEQ("values are not equal", 1, 2);
  a.assertTrue("true is true", 1);
  a.assertFalse("false is false", 0);
  a.assertEquals("strings match", "some-string", "some-string");
  a.assertNotEquals("strings differ", "some-string", "some-other-string");
}

sub main() {
  testRkrUnit();
}

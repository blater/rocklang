include "Assert.rkr"
Assert a;

record Person {
  name: string,
  age:  int
}

record Team {
  leader:  string,         // TODO allow    string leader,
  members: string[]        // TODO allow    string[]  members
}

sub main() {
  // Test 1: Simple string concat
  string s1 := "hello";
  string s2 := concat(s1, " world");
  a.AssertEquals("concat result", "hello world", s2);

  // Test 2: Dynamic string arrays
  string[] names := [];
  append(names, "Alice");
  append(names, "Bob");
  append(names, "Charlie");
  a.AssertEquals("array[0]", "Alice", get(names, 0));
  a.AssertEquals("array[1]", "Bob", get(names, 1));
  a.AssertEquals("array[2]", "Charlie", get(names, 2));
  a.AssertEQ("array length", 3, length(names));

  // Test 3: String concatenation in loop
  for i := 0 to 2 {
    string s := concat("Index ", toString(i));
  }

  // Test 4: Records with strings
  Person p1 := {name := "Alice", age := 30};
  Person p2 := {name := "Bob", age := 25};
  a.AssertEquals("Person p1 name", "Alice", p1.name);
  a.AssertEQ("Person p1 age", 30, p1.age);
  a.AssertEquals("Person p2 name", "Bob", p2.name);
  a.AssertEQ("Person p2 age", 25, p2.age);

  // Test 5: Records with dynamic string arrays
  Team team := {leader := "Alice", members := []};
  append(team.members, "Alice");
  append(team.members, "Bob");
  append(team.members, "Charlie");
  a.AssertEquals("Team leader", "Alice", team.leader);
  a.AssertEquals("Team members[0]", "Alice", get(team.members, 0));
  a.AssertEquals("Team members[1]", "Bob", get(team.members, 1));
  a.AssertEquals("Team members[2]", "Charlie", get(team.members, 2));

  // Test 6: Nested scopes with concat
  for i := 0 to 2 {
    string prefix := concat("Item ", toString(i));
  }

  // Test 7: Dynamic array append and reassign
  string[] items := [];
  append(items, "first");
  a.AssertEquals("initial array item", "first", get(items, 0));
  items[0] := "second";
  a.AssertEquals("reassigned array item", "second", get(items, 0));

  // Test 8: String concatenation chain
  string result := concat("Hello", " ");
  result := concat(result, "World");
  result := concat(result, "!");
  a.AssertEquals("concat chain", "Hello World!", result);

  // Test 9: Deep nesting with concat
  for i := 0 to 1 {
    for j := 0 to 1 {
      string msg := concat("i=", toString(i));
      msg := concat(msg, ", j=");
      msg := concat(msg, toString(j));
    }
  }

  // Test 10: Many iterations (loop allocation reuse)
  for i := 0 to 9 {
    string s := concat("Count: ", toString(i));
  }
}

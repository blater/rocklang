include "Assert.rkr"

// Host test for nextreg component. The host stub is a 256-byte
// shadow register file, so set/get are a simple round-trip.
// Hex values are written in decimal since Rock's lexer does not
// currently accept 0x-prefixed literals.

sub main() {
  Assert a;

  // Round-trip arbitrary registers.
  next_reg_set(to_byte(3), to_byte(170));   // 0x03 := 0xAA
  a.AssertEQ("reg 3 round-trip",
             170, to_int(next_reg_get(to_byte(3))));

  next_reg_set(to_byte(34), to_byte(85));   // 0x22 := 0x55
  a.AssertEQ("reg 34 round-trip",
             85, to_int(next_reg_get(to_byte(34))));

  // cpu_speed_set/get masks to the low two bits.
  cpu_speed_set(to_byte(2));
  a.AssertEQ("cpu speed 2", 2, to_int(cpu_speed_get()));

  cpu_speed_set(to_byte(3));
  a.AssertEQ("cpu speed 3", 3, to_int(cpu_speed_get()));

  // Upper bits of the speed arg are masked away (0xFF -> 3).
  cpu_speed_set(to_byte(255));
  a.AssertEQ("cpu speed masked", 3, to_int(cpu_speed_get()));

  // mmu_set writes reg 0x50 + slot.
  mmu_set(to_byte(0), to_byte(10));
  a.AssertEQ("mmu slot 0 -> reg 80",
             10, to_int(next_reg_get(to_byte(80))));

  mmu_set(to_byte(7), to_byte(99));
  a.AssertEQ("mmu slot 7 -> reg 87",
             99, to_int(next_reg_get(to_byte(87))));

  // Out-of-range slot is a silent no-op.
  mmu_set(to_byte(8), to_byte(123));
  a.AssertEQ("mmu slot 8 ignored",
             0, to_int(next_reg_get(to_byte(88))));
}

include "Assert.rkr"

// Host-target test for the border RTL component. The host stub shadows the
// last colour written, so border_get() must return what border() set.

sub main() {
  Assert a;

  border(2);
  byte c1 := border_get();
  a.AssertEQ("border red shadow", 2, to_int(c1));

  border(4);
  byte c2 := border_get();
  a.AssertEQ("border green shadow", 4, to_int(c2));

  // Colour values above 7 should be masked to low 3 bits.
  border(15);
  byte c3 := border_get();
  a.AssertEQ("border mask high bits", 7, to_int(c3));
}

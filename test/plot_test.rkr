include "Assert.rkr"

// Host smoke test for plot(byte x, byte y).
// Under run_tests.sh stdout is piped so host_caps.plot is 0 and the
// fallback branch emits plain-text log lines. We only assert that
// the calls return normally.

sub main() {
  Assert a;
  int i := 0;

  // Corners + centre + y-boundary clip.
  plot(0,   0);
  plot(255, 0);
  plot(0,   191);
  plot(255, 191);
  plot(128, 96);

  // y >= 192 should be clipped silently.
  plot(10, 200);

  // Diagonal line.
  for i := 0 to 63 {
    plot(to_byte(i), to_byte(i));
  }

  a.AssertEQ("plot smoke", 1, 1);
}

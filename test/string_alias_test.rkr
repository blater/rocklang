// ADR-0003 §10.6: identifier-to-identifier string assignment is a
// descriptor copy + retain (not a deep copy).
//
// Both aliases share backing; refcount tracks live references; cleanup
// dec's once per alias. This test exercises:
//   1. Aliasing of a longlived-backed string (concat result).
//   2. Aliasing of a static-backed string (literal).
//   3. Aliasing in a loop where each iteration creates and drops aliases.
//
// Under the legacy deep-copy path, every alias was its own allocation.
// Under the new retain path, aliases share backing and refcount drives
// reclamation.

include "Assert.rkr"

Assert as;

sub main() {
  // Case 1: alias a concat result.
  string s := concat("hello, ", "world");
  string t := s;       // descriptor copy + retain
  string u := t;       // another alias
  as.AssertEquals("alias of concat preserves content (s)", "hello, world", s);
  as.AssertEquals("alias of concat preserves content (t)", "hello, world", t);
  as.AssertEquals("alias of concat preserves content (u)", "hello, world", u);

  // Case 2: alias a literal.
  string lit := "static";
  string lit_alias := lit;
  as.AssertEquals("alias of literal preserves content", "static", lit_alias);

  // Case 3: tight loop creating and dropping aliases.
  // Each iteration: produce → alias → drop both at iteration end.
  for i := 1 to 1000 {
    string a := toString(i);
    string b := a;     // alias
    // both go out of scope; refcount on backing dec'd twice.
  }
  as.AssertEQ("loop alias survived 1000 iterations", 1, 1);
}

include "Assert.rkr"
Assert a;

sub main() {
  // Basic byte variable and to_string
  byte b := 65;
  a.AssertEquals("byte value", "65", toString(b));

  // to_int
  int n := to_int(b);
  a.AssertEquals("to_int", "65", toString(n));

  // to_byte
  byte b2 := to_byte(200);
  a.AssertEquals("to_byte(200)", "200", toString(b2));

  // Silent truncation: 300 mod 256 = 44
  byte b3 := to_byte(300);
  a.AssertEquals("to_byte(300) truncated", "44", toString(b3));

  // Arithmetic via int promotion
  int sum := to_int(b) + to_int(b2);
  a.AssertEquals("65 + 200", "265", toString(sum));

  // byte arrays
  byte[] arr := [];
  append(arr, to_byte(10));
  append(arr, to_byte(20));
  append(arr, to_byte(30));
  a.AssertEQ("array length", 3, length(arr));
  a.AssertEQ("arr[1]", 20, to_int(get(arr, 1)));

  // to_string on int (default _Generic branch)
  int i := 42;
  a.AssertEquals("toString(int)", "42", toString(i));
}

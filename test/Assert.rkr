module Assert;

sub printPass(string desc) {
  printf("PASS: ");
  printf(desc);
  printf("\n");
}

sub printFail(string desc, string expected, string actual) {
  printf("FAIL: ");
  printf(desc);
  printf(" (expected:");
  printf(expected);
  printf(" actual:");
  printf(actual);
  printf(")\n");
}

sub printResult(int res, string desc, string expected, string actual) returns int {
  if (res = 1) {
    printPass(desc);
  } else {
    printFail(desc, expected, actual);
  }
  return res;
}

sub printIntResult(int res, string desc, int expected, int actual) returns int {
  return printResult(res, desc, toString(expected), toString(actual));
}

sub Assert.AssertFalse(string desc, int value) returns int {
  if (value = 1) {
    printFail(desc, "False(0)", toString(value));
    return 0;
  } else {
    printPass(desc);
    return 1;
  }
}

sub Assert.AssertTrue(string desc, int value) returns int {
  if (value = 0) {
    printFail(desc, "TRUE(1)", toString(value));
    return 0;
  } else {
    printPass(desc);
    return 1;
  }
}

sub Assert.AssertEQ(string desc, int expected, int actual) returns int {
  return printIntResult((expected = actual), desc, expected, actual);
}

sub Assert.AssertNEQ(string desc, int expected, int actual) returns int {
  return printIntResult((expected != actual), desc, expected, actual);
}

sub Assert.AssertEquals(string desc, string expected, string actual) returns int {
  return printResult(equals(expected, actual)!=0, desc, expected, actual);
}

sub Assert.AssertNotEquals(string desc, string expected, string actual) returns int {
  return printResult(equals(expected, actual)=0, desc, expected, actual);
}

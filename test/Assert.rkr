module Assert;

sub printPass(desc: string) {
  printf("PASS: ");
  printf(desc);
  printf("\n");
}

sub printFail(desc: string, expected: string, actual: string) {
  printf("FAIL: ");
  printf(desc);
  printf(" (expected:");
  printf(expected);
  printf(" actual:");
  printf(actual);
  printf(")\n");
}

sub printResult(res: int, desc: string, expected: string, actual: string): int {
  if (res = 1) {
    printPass(desc);
  } else {
    printFail(desc, expected, actual);
  }
  return res;
}

sub printIntResult(res: int, desc: string, expected: int, actual: int): int {
  return printResult(res, desc, to_string(expected), to_string(actual));
}

sub Assert.AssertFalse(desc: string, value: int): int {
  if (value = 1) {
    printFail(desc, "False(0)", to_string(value));
    return 0;
  } else {
    printPass(desc);
    return 1;
  }
}

sub Assert.AssertTrue(desc: string, value: int): int {
  if (value = 0) {
    printFail(desc, "TRUE(1)", to_string(value));
    return 0;
  } else {
    printPass(desc);
    return 1;
  }
}

sub Assert.AssertEQ(desc: string, expected: int, actual: int): int {
  return printIntResult((expected = actual), desc, expected, actual);
}

sub Assert.AssertNEQ(desc: string, expected: int, actual: int): int {
  return printIntResult((expected != actual), desc, expected, actual);
}

sub Assert.AssertEquals(desc: string, expected: string, actual: string): int {
  return printResult(str_eq(expected, actual)!=0, desc, expected, actual);
}

sub Assert.AssertNotEquals(desc: string, expected: string, actual: string): int {
  return printResult(str_eq(expected, actual)=0, desc, expected, actual);
}

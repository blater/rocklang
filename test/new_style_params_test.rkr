include "Assert.rkr"

record Point {
  x: int,
  y: int,
}

sub Point.distance(int dx, int dy): int {
  return this.x + dx + this.y + dy;
}

sub add(int x, int y): int {
  return x + y;
}

sub greet(string name): string {
  return concat("hello ", name);
}

sub first(string[] arr): string {
  return get(arr, 0);
}

sub mixed(int x, y: int): int {
  return x + y;
}

sub main(): void {
  Assert a;
  a.AssertEQ("int params", 7, add(3, 4));
  a.AssertEquals("string param", "hello world", greet("world"));

  Point p := {x := 1, y := 2};
  a.AssertEQ("record param", 13, p.distance(5, 5));

  string[] words;
  append(words, "rock");
  append(words, "on");
  a.AssertEquals("array param", "rock", first(words));

  a.AssertEQ("mixed style params", 9, mixed(4, 5));
}

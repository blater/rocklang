include "Assert.rkr"
Assert a;

sub main() {
  // Basic range loop without =>
  int sum := 0;
  for i := 0 to 4 {
    sum := sum + i;
  }
  a.AssertEQ("sum 0..4", 10, sum);

  // Single-iteration loop (start == end, runs once)
  int count := 0;
  for i := 0 to 0 {
    count := count + 1;
  }
  a.AssertEQ("single iteration", 1, count);

  // Nested loops without =>
  int pairs := 0;
  for i := 0 to 2 {
    for j := 0 to 2 {
      pairs := pairs + 1;
    }
  }
  a.AssertEQ("nested loops 3x3", 9, pairs);
}

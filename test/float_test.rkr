include "Assert.rkr"

// Host test for the float type and math component.
// Covers: decimal literals, default-init, arithmetic, to_float
// coercion, and the libm-backed math builtins.

sub main() {
  Assert a;
  float x;
  float y := 3.14;
  float z := 0.0;
  int n := 4;

  // Default-init leaves x at 0.
  a.AssertEQ("float default 0", 0, to_int(x));

  // Literal round-trip via cast.
  a.AssertEQ("literal 3.14 -> 3", 3, to_int(y));

  // Arithmetic on floats — (3.14 * 2.0) truncated = 6.
  z := y * 2.0;
  a.AssertEQ("3.14 * 2.0 -> 6", 6, to_int(z));

  // to_float on an int.
  x := to_float(n);
  a.AssertEQ("to_float(4) -> 4", 4, to_int(x));

  // fsqrt(16.0) = 4
  x := fsqrt(16.0);
  a.AssertEQ("fsqrt(16) -> 4", 4, to_int(x));

  // fabs_float(-5.5) truncated = 5
  x := fabs_float(0.0 - 5.5);
  a.AssertEQ("fabs(-5.5) -> 5", 5, to_int(x));

  // fsin(0) = 0
  x := fsin(0.0);
  a.AssertEQ("fsin(0) -> 0", 0, to_int(x));

  // fcos(0) = 1
  x := fcos(0.0);
  a.AssertEQ("fcos(0) -> 1", 1, to_int(x));

  // fpi() truncated = 3
  x := fpi();
  a.AssertEQ("fpi -> 3", 3, to_int(x));
}

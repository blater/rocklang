include "Assert.rkr"
Assert a;

// @embed asm blocks are emitted as #asm/#endasm for SDCC/Z88DK.
// On host/GCC the block is skipped; the function returns normally.
sub asm_nop(): void {
  @embed asm
    ld a, 0
    ret
  @end asm
}

sub main(): void {
  asm_nop();
  a.AssertEQ("embed asm block compiles and returns cleanly", 1, 1);
}

include "Assert.rkr"

// Host-target test for the keyboard RTL component.
// On host there is no real hardware: scan_keyboard() is a no-op and
// the internal buffer stays zeroed, so every key reports "not pressed".
// The point of this test is to exercise the compiler/builtin/link path
// end-to-end so ZXN builds inherit a known-good foundation.

sub main() {
  Assert a;

  // Calling scan_keyboard() on host must not crash.
  scan_keyboard();

  // Host stub: every key reads as 0 (not pressed).
  byte k5    := key_pressed(0);   // KEY_5
  byte kent  := key_pressed(29);  // KEY_ENT
  byte kspc  := key_pressed(39);  // KEY_SPC

  a.AssertEQ("KEY_5 not pressed on host",   0, to_int(k5));
  a.AssertEQ("KEY_ENT not pressed on host", 0, to_int(kent));
  a.AssertEQ("KEY_SPC not pressed on host", 0, to_int(kspc));

  // Out-of-range key id should return 0 rather than reading past the buffer.
  byte kbad := key_pressed(200);
  a.AssertEQ("out-of-range key id is 0", 0, to_int(kbad));
}

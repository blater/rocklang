include "Assert.rkr"

sub buildGreeting(string name) returns string {
  string result := concat("Hello, ", name);
  return result;
}

sub main() {
  Assert a;

  // Test 1: Basic scope cleanup
  string s1 := concat("Hello", " World");
  a.AssertEquals("concat in scope", "Hello World", s1);

  // Test 2: String reassignment frees old value
  string s2 := "initial";
  s2 := concat("re", "assigned");
  a.AssertEquals("reassignment", "reassigned", s2);

  // Test 3: Loop with string concat (the main memory leak scenario)
  int i := 0;
  string last := "";
  while i < 100 {
    last := concat("iter-", toString(i));
    i := i + 1;
  }
  a.AssertEquals("loop concat last", "iter-99", last);

  // Test 4: Function returning string
  string greeting := buildGreeting("Rock");
  a.AssertEquals("return string from fn", "Hello, Rock", greeting);

  // Test 5: String-to-string copy (deep copy, no aliasing)
  string original := concat("copy", "me");
  string copy := original;
  a.AssertEquals("copy original", "copyme", original);
  a.AssertEquals("copy target", "copyme", copy);

  // Test 6: Nested concat in loop
  i := 0;
  string acc := "";
  while i < 50 {
    acc := concat(acc, "x");
    i := i + 1;
  }
  a.AssertEQ("acc length 50", 50, length(acc));

  // Test 7: toString in loop
  i := 0;
  while i < 100 {
    string temp := toString(i);
    i := i + 1;
  }
  a.AssertTrue("toString loop completed", 1);

  // Test 8: Substring in scope
  string full := "Hello World";
  string part := substring(full, 1, 5);
  a.AssertEquals("substring", "Hello", part);
}

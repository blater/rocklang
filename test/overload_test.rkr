include "Assert.rkr"

// Overloading by arity: two user functions may share a name as long as
// they take a different number of arguments. The generator mangles the
// C-level names as `name__N` where N is the arity.

sub greet() returns string {
  return "hello, stranger";
}

sub greet(string name) returns string {
  return concat("hello, ", name);
}

sub add(int a, int b) returns int {
  return a + b;
}

sub add(int a, int b, int c) returns int {
  return a + b + c;
}

sub main() returns void {
  Assert t;

  t.AssertEquals("greet/0", "hello, stranger", greet());
  t.AssertEquals("greet/1", "hello, Rock",      greet("Rock"));

  t.AssertEQ("add/2", 5, add(2, 3));
  t.AssertEQ("add/3", 9, add(2, 3, 4));
}

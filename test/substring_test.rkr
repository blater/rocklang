include "Assert.rkr"

sub main() {
  Assert a;
  string s := "Hello World";

  a.AssertEquals("index to end A",   "Hello World", substring(s, 1));
  a.AssertEquals("index to end B",   "World",       substring(s, 7));
  a.AssertEquals("index to end C",   " World",      substring(s, 6));

  a.AssertEquals("inclusive range A", "Hello",   substring(s, 1, 5)); 
  a.AssertEquals("inclusive range B", "World",   substring(s, 7, 11));
  a.AssertEquals("inclusive range C", " ",       substring(s, 6, 6));

  a.AssertEquals("indexed from end (negative index) A", "World", substring(s, -5));
  a.AssertEquals("indexed from end (negative index) B", "ld", substring(s, -2));  
  a.AssertEquals("indexed from end (negative index) C", "World", substring(s, -5, -1));

}

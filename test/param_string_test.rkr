include "Assert.rkr"
Assert a;

// Read-only use of string param — safe, no leak
sub greet(string name) returns string {
  return concat("Hello, ", name);
}

// Store string param in record — should deep-copy
record Box {
  string label
}

sub makeBox(string label) returns Box {
  Box b := {label := label};
  return b;
}

sub main() {
  // Test 1: String param read-only
  string msg := greet("World");
  a.AssertEquals("greet result", "Hello, World", msg);

  // Test 2: Caller's string unaffected after function use
  string name := "Alice";
  string greeting := greet(name);
  a.AssertEquals("caller unaffected", "Alice", name);
  a.AssertEquals("greeting correct", "Hello, Alice", greeting);

  // Test 3: String param stored in record (deep-copy)
  string lbl := "fragile";
  Box b := makeBox(lbl);
  a.AssertEquals("box label", "fragile", b.label);

  // Test 4: Stress — call in loop
  string last := "";
  for i := 1 to 50 {
    last := greet(toString(i));
  }
  a.AssertEquals("loop greet", "Hello, 50", last);
}

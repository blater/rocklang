include "test/Assert.rkr"

sub main() {
  dim d: dword := 1000000;
  AssertEquals("Basic dword variable and to_string", "1000000", to_string(d));

  dim n: int := to_int(d);
  AssertEquals("dword to_int", "1000000", to_string(n));

  dim d2: dword := to_dword(2000000);
  AssertEquals("Cast int to_dword(2000000)", "2000000", to_string(d2));

  dim d3: dword := to_dword(2147483647);
  AssertEquals("Max size 32-bit int to_dword(2147483647)", "2147483647", to_string(d3));

  dim sum: int := to_int(d) + to_int(d2);
  AssertEquals("Arithmentic via in promotion(1000000 + 2000000)","3000000", to_string(sum)); 

  dim arr: dword[] := [];
  append(arr, to_dword(100000));
  append(arr, to_dword(200000));
  append(arr, to_dword(300000));
  AssertEQ("dword arrays length", 3, length(arr));
  AssertEQ("dword arrays value", 200000, get(arr,1));

  dim i: int := 42;
  AssertEquals("to_string on int", "42", to_string(i));
}

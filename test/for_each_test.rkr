include "Assert.rkr"
Assert a;

sub main() {
  int[] arr1;
  int sum1 := 0;

  for item in arr1 {
    sum1 := sum1 + item;
  }
  a.AssertEQ("for with in, empty array", 0, sum1);

  // Test 2: for with 'in' separator, default to 0
  int[1] arr2;
  int sum2 := 0;
  for item in arr2 {
    sum2 := sum2 + item;
  }
  a.AssertEQ("for with in, array with default elements", 0, sum2);

  // Test 3: for with ':=' separator
  int[] arr3;
  int sum3 := 0;
  for item := arr3 {
    sum3 := sum3 + item;
  }
  a.AssertEQ("for with :=, empty array", 0, sum3);
}

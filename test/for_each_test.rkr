include "test/Assert.rkr"

sub main() {
  // Test 1: iter with 'in' separator
  dim arr1: int[];
  dim sum1: int := 0;
  iter item in arr1 {
    sum1 := sum1 + item;
  }
  AssertEQ("iter with in, empty array", 0, sum1);

  // Test 2: for with 'in' separator
  dim arr2: int[];
  dim sum2: int := 0;
  for item in arr2 {
    sum2 := sum2 + item;
  }
  AssertEQ("for with in, empty array", 0, sum2);

  // Test 3: for with ':=' separator
  dim arr3: int[];
  dim sum3: int := 0;
  for item := arr3 {
    sum3 := sum3 + item;
  }
  AssertEQ("for with :=, empty array", 0, sum3);

  // Test 4: iter with ':=' separator
  dim arr4: int[];
  dim sum4: int := 0;
  iter item := arr4 {
    sum4 := sum4 + item;
  }
  AssertEQ("iter with :=, empty array", 0, sum4);
}

include "Assert.rkr"
Assert as;

enum jours {
    Lundi,
    Mardi,
    Mercredi,
    Jeudi,
    Vendredi,
    Samedi,
    Dimanche,
}

sub main() {
  as.AssertEQ("Lundi",    0, Lundi);
  as.AssertEQ("Mardi",    1, Mardi);
  as.AssertEQ("Mercredi", 2, Mercredi);
  as.AssertEQ("Jeudi",    3, Jeudi);
  as.AssertEQ("Vendredi", 4, Vendredi);
  as.AssertEQ("Samedi",   5, Samedi);
  as.AssertEQ("Dimanche", 6, Dimanche);
}


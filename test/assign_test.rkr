include "Assert.rkr"
Assert as;

record t {
  int a,
  string b
}

sub modify_t(t arg) {
  arg.b := "hooo\n";
}

sub main() {
  t var := {a := 3, b := "hey !\n"};
  as.AssertEquals("record assignment", "hey !\n", var.b);

  modify_t(var);
  as.AssertEquals("mutation by reference", "hooo\n", var.b);
}
